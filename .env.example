# ─────────────────────────────────────────────────────────────────────────────
# LinguAI — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# HOW TO GET EACH VALUE: See SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Notifications ─────────────────────────────────────────────────────────────
# Create a Slack workspace → api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK

# ── Email ─────────────────────────────────────────────────────────────────────
NOTIFICATION_EMAIL=your@email.com

# ── GitHub ────────────────────────────────────────────────────────────────────
# github.com → Settings → Developer settings → Personal access tokens → Classic
# Required scopes: repo (full)
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_REPO=https://github.com/YOUR_USERNAME/language-learning-app.git

# ── Supabase (Database + Auth + Storage) ─────────────────────────────────────
# Create free project at supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_KEY

# ── Groq AI (Free tier — primary AI provider) ─────────────────────────────────
# Sign up at groq.com → API Keys → Create new key
# Free tier: 14,400 requests/day, Llama 3 70B model
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# ── Google Gemini AI (Free tier — backup AI provider) ─────────────────────────
# Get key at ai.google.dev → Get API key → Create API key
# Free tier: 1,500 requests/day, Gemini 1.5 Flash
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY

# ── Flutter App Config ────────────────────────────────────────────────────────
# Environment: dev | uat | prod
APP_ENV=dev
