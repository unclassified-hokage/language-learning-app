# Environment / secrets — never commit these
.env
.env.local
.env*.local
secrets.json

# Flutter SDK — install separately via scripts/setup.sh, never commit
flutter/
flutter_macos_arm64_*.zip
flutter_linux_*.tar.xz
flutter_windows_*.zip
*.zip

# macOS
.DS_Store
.AppleDouble
.LSOverride
__MACOSX/

# Flutter/Dart
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/build/
app/.pub-cache/
app/.pub/
app/pubspec.lock
app/**/*.g.dart
app/**/*.freezed.dart

# Android
app/android/.gradle/
app/android/local.properties
app/android/captures/
app/android/gradlew
app/android/gradlew.bat
app/android/gradle/

# iOS
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec

# Node (if any tooling)
node_modules/
npm-debug.log*

# IDE
.idea/
.vscode/settings.json
*.iml

# Build outputs
dist/
build/
*.apk
*.ipa
*.aab
